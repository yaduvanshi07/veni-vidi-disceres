<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title + ' - ' : '' %>Document Assistant
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
    <link href="/css/portal.css" rel="stylesheet">
    <!-- Google Fonts & Iconify -->
    <link
        href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700&family=Inter:wght@300;400;500;600&display=swap"
        rel="stylesheet">
    <script src="https://code.iconify.design/3/3.1.0/iconify.min.js"></script>
</head>

<body
    class="<%= typeof user !== 'undefined' && user && user.preferences && user.preferences.theme === 'dark' ? 'dark-mode' : (typeof user !== 'undefined' && user && user.preferences && user.preferences.theme === 'light' ? '' : '') %>">
    <nav
        class="navbar navbar-expand-lg navbar-premium fixed-top <%= typeof user !== 'undefined' && user && user.preferences && user.preferences.theme === 'dark' ? 'navbar-dark' : 'navbar-light' %>">
        <div class="container">
            <a class="navbar-brand brand-premium" href="/">
                <i class="bi bi-mortarboard-fill me-2 text-saffron"></i>Veni · Vidi · Discere
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <% if (typeof user !=='undefined' && user) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/marketplace">
                                <i class="bi bi-shop me-1"></i>Marketplace
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/dashboard">
                                <i class="bi bi-speedometer2 me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/documents/all">
                                <i class="bi bi-folder me-1"></i>Documents
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/analytics/dashboard">
                                <i class="bi bi-graph-up me-1"></i>Analytics
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="studyDropdown" role="button"
                                data-bs-toggle="dropdown">
                                <i class="bi bi-book me-1"></i>Study
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/study/flashcards">
                                        <i class="bi bi-card-text me-2"></i>Flashcards
                                    </a></li>
                                <li><a class="dropdown-item" href="/study/exams">
                                        <i class="bi bi-calendar-event me-2"></i>Exams
                                    </a></li>
                            </ul>
                        </li>
                        <% if (user.role==='admin' ) { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/admin">
                                    <i class="bi bi-shield-check me-1"></i>Admin
                                </a>
                            </li>
                            <% } %>
                                <% } else { %>
                                    <li class="nav-item">
                                        <a class="nav-link" href="/">Home</a>
                                    </li>
                                    <% } %>
                </ul>
                <ul class="navbar-nav">
                    <% if (typeof user !=='undefined' && user) { %>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button"
                                data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>
                                <%= user.username %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/dashboard">
                                        <i class="bi bi-speedometer2 me-2"></i>Dashboard
                                    </a></li>
                                <li>
                                    <hr class="dropdown-divider">
                                </li>
                                <li>
                                    <button class="dropdown-item" id="themeToggle">
                                        <i class="bi bi-moon-stars me-2"></i>Toggle Theme
                                    </button>
                                </li>
                                <li>
                                    <hr class="dropdown-divider">
                                </li>
                                <li>
                                    <form action="/logout" method="POST" class="d-inline">
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                        <% } else { %>
                            <li class="nav-item">
                                <a class="nav-link btn btn-ghost px-4 me-2" href="/login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-pill-gradient text-white px-4" href="/signup">Sign Up</a>
                            </li>
                            <% } %>
                </ul>
            </div>
        </div>
    </nav>