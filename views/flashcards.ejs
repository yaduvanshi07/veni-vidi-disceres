<%- include('partials/header', { title: 'Flashcards' , user: user }) %>

    <main class="container my-5">
        <!-- Page Header -->
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h1 class="h2 fw-bold mb-1 text-dark" style="font-family: 'Cinzel', serif;">
                    Flashcards
                </h1>
                <p class="text-muted mb-0">Review and master key concepts with spaced repetition</p>
            </div>
            <button class="btn btn-pill-gradient text-white btn-lg shadow-sm px-4" data-bs-toggle="modal"
                data-bs-target="#generateModal">
                <i class="bi bi-magic me-2"></i>Generate New Deck
            </button>
        </div>

        <!-- Filters -->
        <div class="card glass-card border-0 shadow-sm mb-5">
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label for="filterTopic" class="form-label fw-bold text-muted small text-uppercase">
                            <i class="bi bi-tag me-2 text-saffron"></i>Topic
                        </label>
                        <select class="form-select border-0 bg-light fw-medium py-2" id="filterTopic">
                            <option value="">All Topics</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="filterDifficulty" class="form-label fw-bold text-muted small text-uppercase">
                            <i class="bi bi-bar-chart me-2 text-saffron"></i>Difficulty
                        </label>
                        <select class="form-select border-0 bg-light fw-medium py-2" id="filterDifficulty">
                            <option value="">All Levels</option>
                            <option value="Easy">Easy</option>
                            <option value="Medium">Medium</option>
                            <option value="Hard">Hard</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="filterDue" class="form-label fw-bold text-muted small text-uppercase">
                            <i class="bi bi-clock me-2 text-saffron"></i>Review Status
                        </label>
                        <select class="form-select border-0 bg-light fw-medium py-2" id="filterDue">
                            <option value="all">All Cards</option>
                            <option value="due">Due for Review</option>
                            <option value="new">New Cards</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button class="btn btn-pill-gradient text-white w-100 py-2 shadow-sm fw-bold"
                            onclick="loadFlashcards()">
                            <i class="bi bi-funnel me-2"></i>Apply Filters
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="row g-4 mb-5" id="statsCards" style="display: none;">
            <div class="col-md-3">
                <div class="card glass-card border-0 shadow-sm text-center py-3">
                    <div class="card-body">
                        <h6 class="text-uppercase small fw-bold text-muted mb-2 tracking-wide">Total Cards</h6>
                        <h2 class="mb-0 fw-bold display-6 text-dark" id="totalCards">0</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card glass-card border-0 shadow-sm text-center py-3">
                    <div class="card-body">
                        <h6 class="text-uppercase small fw-bold text-muted mb-2 tracking-wide">Due for Review</h6>
                        <h2 class="mb-0 fw-bold display-6 text-saffron" id="dueCards">0</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card glass-card border-0 shadow-sm text-center py-3">
                    <div class="card-body">
                        <h6 class="text-uppercase small fw-bold text-muted mb-2 tracking-wide">Mastered</h6>
                        <h2 class="mb-0 fw-bold display-6 text-success" id="masteredCards">0</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card glass-card border-0 shadow-sm text-center py-3">
                    <div class="card-body">
                        <h6 class="text-uppercase small fw-bold text-muted mb-2 tracking-wide">Average Mastery</h6>
                        <h2 class="mb-0 fw-bold display-6 text-info" id="avgMastery">0%</h2>
                    </div>
                </div>
            </div>
        </div>

        <!-- Flashcard Review Area -->
        <div id="flashcardArea" class="text-center py-5">
            <div class="spinner-border text-saffron" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Loading flashcards...</span>
            </div>
            <p class="mt-3 text-muted">Loading your deck...</p>
        </div>

        <!-- Flashcard Grid (List View) -->
        <div id="flashcardGrid" style="display: none;">
            <div class="row g-4" id="flashcardList">
                <!-- Cards will be loaded here -->
            </div>
        </div>
    </main>

    <!-- Generate Flashcards Modal -->
    <div class="modal fade" id="generateModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-gradient-primary text-white border-0">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-magic me-2"></i>Generate Flashcards
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="generateForm">
                        <div class="mb-4">
                            <label for="generateDocument" class="form-label fw-semibold">
                                <i class="bi bi-file-earmark me-2 text-primary"></i>Select Document
                            </label>
                            <select class="form-select form-select-lg" id="generateDocument" required>
                                <option value="">Choose a document...</option>
                            </select>
                            <div class="form-text">
                                <i class="bi bi-info-circle me-1"></i>Document must be parsed first
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="bi bi-magic me-2"></i>Generate Flashcards
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Flashcard Review Modal -->
    <div class="modal fade" id="reviewModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-gradient-info text-white border-0">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-card-text me-2"></i>Flashcard Review
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-5">
                    <div id="flashcardContent" class="flashcard-container">
                        <!-- Flashcard will be displayed here -->
                    </div>
                    <div class="mt-4 text-center" id="reviewButtons" style="display: none;">
                        <button class="btn btn-danger btn-lg me-2" onclick="reviewFlashcard(false)">
                            <i class="bi bi-x-circle me-2"></i>Incorrect
                        </button>
                        <button class="btn btn-success btn-lg" onclick="reviewFlashcard(true)">
                            <i class="bi bi-check-circle me-2"></i>Correct
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/flashcards.js"></script>
    <style>
        .flashcard-container {
            min-height: 350px;
            display: flex;
            align-items: center;
            justify-content: center;
            perspective: 1000px;
        }

        .flashcard {
            width: 600px;
            /* Wider card for better readability */
            max-width: 100%;
            height: 350px;
            position: relative;
            transform-style: preserve-3d;
            transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            /* Bouncy transition */
            cursor: pointer;
        }

        .flashcard.flipped {
            transform: rotateY(180deg);
        }

        .flashcard-face {
            position: absolute;
            width: 100%;
            height: 100%;
            backface-visibility: hidden;
            border-radius: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            /* Softer, larger shadow */
            overflow: hidden;
        }

        .flashcard-front {
            background: white;
            /* Clean white list style */
            color: #2c3e50;
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        /* Premium gradient border approach for front */
        .flashcard-front::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 6px;
            background: linear-gradient(90deg, #FF9933, #00CED1);
        }

        .flashcard-back {
            background: #FF9933;
            /* Saffron standard */
            background: linear-gradient(135deg, #FF9933 0%, #FFB366 100%);
            color: white;
            transform: rotateY(180deg);
        }

        .flashcard-text {
            font-size: 1.5rem;
            font-weight: 500;
            text-align: center;
            line-height: 1.6;
            font-family: 'Outfit', sans-serif;
        }

        .flashcard-badge {
            position: absolute;
            top: 1.5rem;
            right: 1.5rem;
        }
    </style>
    <%- include('partials/footer') %>