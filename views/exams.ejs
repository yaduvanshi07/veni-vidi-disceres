<%- include('partials/header', { title: 'Exams', user: user }) %>

<main class="container my-5">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 fw-bold mb-1">
                <i class="bi bi-calendar-event me-2 text-primary"></i>Exams
            </h1>
            <p class="text-muted mb-0">Manage your exam schedule and reminders</p>
        </div>
        <button class="btn btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#examModal">
            <i class="bi bi-plus-circle me-2"></i>Add Exam
        </button>
    </div>

    <!-- Upcoming Exams -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-gradient-primary text-white border-0">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-calendar-check me-2"></i>Upcoming Exams
            </h5>
        </div>
        <div class="card-body p-4">
            <div id="upcomingExams" class="text-center py-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        </div>
    </div>

    <!-- All Exams -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pb-0 pt-4 px-4">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-list-ul me-2 text-primary"></i>All Exams
            </h5>
        </div>
        <div class="card-body p-4">
            <div id="allExams" class="text-center py-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        </div>
    </div>
</main>

<!-- Add/Edit Exam Modal -->
<div class="modal fade" id="examModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-gradient-success text-white border-0">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-calendar-plus me-2"></i>Add Exam
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="examForm">
                    <div class="mb-3">
                        <label for="examTitle" class="form-label fw-semibold">
                            <i class="bi bi-pencil me-2 text-success"></i>Exam Title
                        </label>
                        <input type="text" class="form-control form-control-lg" id="examTitle" required placeholder="e.g., Final Exam - Mathematics">
                    </div>
                    <div class="mb-3">
                        <label for="examDescription" class="form-label fw-semibold">
                            <i class="bi bi-info-circle me-2 text-success"></i>Description
                        </label>
                        <textarea class="form-control form-control-lg" id="examDescription" rows="2" placeholder="Additional details about the exam..."></textarea>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label for="examDate" class="form-label fw-semibold">
                                <i class="bi bi-calendar me-2 text-success"></i>Exam Date
                            </label>
                            <input type="date" class="form-control form-control-lg" id="examDate" required>
                        </div>
                        <div class="col-md-6">
                            <label for="examTime" class="form-label fw-semibold">
                                <i class="bi bi-clock me-2 text-success"></i>Time
                            </label>
                            <input type="time" class="form-control form-control-lg" id="examTime">
                        </div>
                    </div>
                    <div class="mb-4">
                        <label for="examLocation" class="form-label fw-semibold">
                            <i class="bi bi-geo-alt me-2 text-success"></i>Location
                        </label>
                        <input type="text" class="form-control form-control-lg" id="examLocation" placeholder="e.g., Room 101, Building A">
                    </div>
                    <button type="submit" class="btn btn-success btn-lg w-100">
                        <i class="bi bi-check-circle me-2"></i>Save Exam
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="/js/exams.js"></script>
<style>
.countdown-card {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-radius: 1rem;
    padding: 2rem;
    margin-bottom: 1rem;
}

.countdown-number {
    font-size: 3rem;
    font-weight: bold;
}

.countdown-label {
    font-size: 0.875rem;
    opacity: 0.9;
}

.exam-card {
    transition: transform 0.2s, box-shadow 0.2s;
}

.exam-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
}

.urgent {
    border-left: 4px solid #dc3545;
}

.upcoming {
    border-left: 4px solid #ffc107;
}

.future {
    border-left: 4px solid #198754;
}
</style>
<%- include('partials/footer') %>

