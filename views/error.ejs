<%- include('partials/header', { title: 'Error', user: user }) %>

<main class="container my-5">
    <div class="row justify-content-center align-items-center min-vh-75">
        <div class="col-md-8 col-lg-6 text-center">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <div class="error-icon bg-danger bg-opacity-10 rounded-circle d-inline-flex p-4 mb-3">
                            <i class="bi bi-exclamation-triangle-fill text-danger display-3"></i>
                        </div>
                    </div>
                    <h2 class="fw-bold mb-3">Oops! Something went wrong</h2>
                    <p class="text-muted mb-4 lead">
                        <%= typeof error !== 'undefined' ? error : 'An unexpected error occurred' %>
                    </p>
                    <div class="d-flex gap-3 justify-content-center">
                        <a href="/dashboard" class="btn btn-primary btn-lg">
                            <i class="bi bi-house me-2"></i>Go to Dashboard
                        </a>
                        <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg">
                            <i class="bi bi-arrow-left me-2"></i>Go Back
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
