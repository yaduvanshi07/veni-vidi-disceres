<%- include('../partials/header', { title: 'Secure Payment' , user: user }) %>

    <main class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card glass-card border-0 shadow-lg">
                    <div class="card-header bg-white border-0 pt-4 pb-0 text-center">
                        <h4 class="fw-bold mb-0 text-dark">Unlock Access</h4>
                    </div>
                    <div class="card-body p-4">
                        <div class="text-center mb-4">
                            <div class="bg-light rounded p-3 mb-3 d-inline-block">
                                <i class="bi bi-file-earmark-text fs-1 text-saffron"></i>
                            </div>
                            <h5 class="fw-bold mb-1">
                                <%= paper.originalName %>
                            </h5>
                            <p class="text-muted small">
                                <%= paper.courseId.name %> • <%= paper.year %> Year
                            </p>
                        </div>

                        <div class="bg-light rounded p-3 mb-4">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Base Price</span>
                                <span class="fw-bold">₹<%= pricing.basePrice.toFixed(2) %></span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">GST (18%)</span>
                                <span class="fw-bold">₹<%= pricing.gst.toFixed(2) %></span>
                            </div>
                            <div class="d-flex justify-content-between mb-3">
                                <span class="text-muted">Platform Fee</span>
                                <span class="fw-bold">₹<%= pricing.platformFee.toFixed(2) %></span>
                            </div>
                            <hr class="my-2">
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="fw-bold text-dark fs-5">Total Payable</span>
                                <span class="fw-bold text-success fs-4">₹<%= pricing.finalAmount.toFixed(2) %></span>
                            </div>
                        </div>

                        <button id="payBtn" class="btn btn-saffron w-100 py-3 fw-bold shadow-sm">
                            <i class="bi bi-credit-card-2-front me-2"></i>Pay ₹<%= pricing.finalAmount.toFixed(2) %> &
                                Access
                        </button>

                        <div class="text-center mt-3">
                            <small class="text-muted"><i class="bi bi-shield-lock-fill me-1"></i>Secure Payment
                                Simulation</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        document.getElementById('payBtn').addEventListener('click', async function () {
            const btn = this;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Processing...';

            try {
                const response = await fetch('/payment/<%= paper._id %>/confirm', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                const result = await response.json();

                if (result.success) {
                    // Redirect to the document page
                    window.location.href = result.redirectUrl;
                } else {
                    alert('Payment failed: ' + result.message);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-credit-card-2-front me-2"></i>Pay ₹<%= pricing.finalAmount.toFixed(2) %> & Access';
                }
            } catch (error) {
                console.error(error);
                alert('An error occurred during payment');
                btn.disabled = false;
            }
        });
    </script>

    <%- include('../partials/footer') %>