<%- include('../partials/header', { title: 'Select Course' , user: user }) %>

    <main class="container py-5">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb breadcrumb-custom">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-saffron">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page">
                    <%= institution.name %>
                </li>
            </ol>
        </nav>

        <h2 class="fw-bold mb-4 text-dark">Select Course</h2>

        <div class="row g-4">
            <% if (courses && courses.length> 0) { %>
                <% courses.forEach(course=> { %>
                    <div class="col-md-6 col-lg-3">
                        <a href="/institute/<%= institution._id %>/course/<%= course._id %>/years"
                            class="text-decoration-none">
                            <div class="card glass-card h-100 text-center border-0 p-4 hover-lift">
                                <div class="card-body">
                                    <div class="mb-3">
                                        <i class="bi bi-laptop fs-1 text-aqua"></i>
                                    </div>
                                    <h5 class="fw-bold text-dark">
                                        <%= course.name %>
                                    </h5>
                                    <p class="text-muted small mb-0">
                                        <%= course.code || '' %>
                                    </p>
                                </div>
                            </div>
                        </a>
                    </div>
                    <% }); %>
                        <% } else { %>
                            <div class="col-12 text-center">
                                <p class="text-muted">No courses available for this institute.</p>
                            </div>
                            <% } %>
        </div>
    </main>

    <%- include('../partials/footer') %>